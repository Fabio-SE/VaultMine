# =============================================================================
# VAULT WEB — .gitignore
# Stack: Python / FastAPI / Uvicorn + React / Vite / Tailwind + Jupyter
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[codz]
*$py.class
*.so
*.pyd

# Distribuição / empacotamento
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Instaladores
pip-log.txt
pip-delete-this-directory.txt

# Testes / cobertura
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Tipo / análise estática
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/

# Ambientes virtuais
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
__pypackages__/

# Ferramentas de gerenciamento de dependências
.pdm-python
.pdm-build/
.pixi
.pypirc

# IDEs Python
.spyderproject
.spyproject
.ropeproject

# Misc Python
*.log
tempCodeRunnerFile.py


# -----------------------------------------------------------------------------
# FastAPI / Uvicorn
# -----------------------------------------------------------------------------
# Arquivos de instância da aplicação (ex: SQLite local, uploads temporários)
instance/
*.db
*.sqlite3
*.sqlite3-journal

# Logs de servidor
logs/
*.log

# Arquivos gerados em runtime
*.pid
*.sock


# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/


# -----------------------------------------------------------------------------
# Node.js / npm / pnpm / yarn (frontend React + Vite)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Lock files (descomente a linha do gerenciador que você NÃO usa)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build do Vite / React
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/.vite/

# Cache do Vite
frontend/.cache/

# Tailwind / PostCSS gerados
frontend/src/styles/output.css


# -----------------------------------------------------------------------------
# Variáveis de ambiente e segredos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.envrc
secrets.*
*.pem
*.key
*.cert
*.p12

# Streamlit
.streamlit/secrets.toml


# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
# VS Code (descomente se quiser ignorar configs locais)
# .vscode/

# JetBrains / PyCharm
.idea/

# Vim / Neovim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
/site
docs/_build/
.pybuilder/
target/
